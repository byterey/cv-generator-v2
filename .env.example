# Copy this file to .env and fill in your real values.
# .env is gitignored and will never be committed.

# ── AI / API keys ──────────────────────────────────────────────────────────────
# Required if you use AI-powered tailoring features (Claude API)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional overrides ─────────────────────────────────────────────────────────
# Default paths (override if you store your CV data elsewhere)
# CV_DATA_PATH=./cv.yml
# OUTPUT_DIR=./output
