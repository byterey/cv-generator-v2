{
  "name": "cv-generator",
  "version": "2.0.0",
  "description": "ATS-friendly CV/resume generator — renders structured YAML data to HTML and PDF via Handlebars and Puppeteer",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/byterey/cv-generator-v2",
  "repository": {
    "type": "git",
    "url": "https://github.com/byterey/cv-generator-v2.git"
  },
  "scripts": {
    "build": "node src/generate.js",
    "build:html": "node src/generate.js --html-only",
    "tailor": "node src/tailor.js",
    "sync:agents": "node scripts/sync-agent-files.js"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "marked": "^12.0.0",
    "puppeteer": "^22.0.0"
